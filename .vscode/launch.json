{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch CSX Extension (use this for CSX editing)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode-extensions/csx-language",
                "${workspaceFolder}"
            ],
            "outFiles": ["${workspaceFolder}/vscode-extensions/csx-language/out/**/*.js"]
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}